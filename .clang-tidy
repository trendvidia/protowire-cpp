#
# clang-tidy configuration for protowire-cpp.
#
# Conservative starting rule set — high signal, low noise. Categories:
#
#   bugprone-*      likely bugs (use-after-move, sizeof mistakes,
#                   suspicious string compare, etc.)
#   cert-*          security-relevant patterns
#   performance-*   unnecessary copies, slow constructions
#   modernize-use-{equals-default,equals-delete,nullptr,override}
#                   four-rule subset of modernize that flags real
#                   maintenance issues without forcing the codebase
#                   into trailing-return-type / default-member-init
#                   stylistic conventions.
#
# Exclusions (and why):
#   bugprone-easily-swappable-parameters  — false-positive heavy
#   bugprone-narrowing-conversions        — protobuf reflection forces
#                                            int32/int64 narrowings
#   bugprone-branch-clone                 — false-positive on
#                                            `if constexpr` type-dispatch
#                                            chains where independent
#                                            branches happen to share a
#                                            return value
#   cert-err58-cpp / cert-msc30-c /
#   cert-msc50-cpp                        — relax for static-init and
#                                            POSIX rand() in fixtures
#   performance-no-int-to-ptr             — clashes with packed-bit
#                                            decoders
#   performance-unnecessary-value-param   — we sometimes pass strings
#                                            by value to allow std::move
#                                            into local
#
# Suppressions are line-scoped via `// NOLINT(rule-name)` with a
# one-line comment explaining why; whole-file or whole-function
# suppressions need maintainer approval.

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-branch-clone,
  -bugprone-switch-missing-default-case,
  cert-*,
  -cert-err33-c,
  -cert-err58-cpp,
  -cert-msc30-c,
  -cert-msc50-cpp,
  performance-*,
  -performance-no-int-to-ptr,
  -performance-unnecessary-value-param,
  -performance-inefficient-string-concatenation,
  modernize-use-equals-default,
  modernize-use-equals-delete,
  modernize-use-nullptr,
  modernize-use-override,

# (deferred) These three rules each surface 1–3 real candidate sites that
# would benefit from a small refactor (snprintf return-value handling,
# string-concat in big.cc, missing default in lexer switch). They're
# disabled in the initial gate so CI is green; an issue tracks
# re-enabling them after the candidate sites are addressed:
#   - cert-err33-c
#   - bugprone-switch-missing-default-case
#   - performance-inefficient-string-concatenation

WarningsAsErrors: ''
HeaderFilterRegex: '^(include|src)/protowire/.*'
FormatStyle: file
